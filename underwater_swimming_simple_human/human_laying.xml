<mujoco model="human_swimmer">
    <option gravity="0 0 0" timestep="0.005" viscosity="0.0013" density="1000">
        <flag energy="enable"/>
    </option>

    <asset>
        <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
        <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
    </asset>

    <default>
        <joint damping="0.5"/>
        <geom friction="0.01 0.01 0.01"/>
    </default>

    <worldbody>
        <!-- Main Directional Light -->
        <light name="sun" pos="0 0 10" dir="0.2 -0.2 -1" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3" castshadow="true"/>
        <!-- Fill Light -->
        <light name="fill" pos="0 0 -5" dir="0 0 1" diffuse="0.3 0.3 0.4" specular="0.1 0.1 0.1"/>
        <!-- Ambient Light -->
        <light name="ambient" pos="0 0 0" diffuse="0.1 0.1 0.2" specular="0 0 0"/>

        <geom name="floor" type="plane" size="0 0 .05" material="grid" condim="3" rgba="0.1 0.4 0.6 1"/>

        <camera name="main_camera" pos="10 10 10" xyaxes="1 0 0 0 0 1"/>
        <camera name="chase_cam" pos="0 -4 2" mode="trackcom" xyaxes="0 1 0 0 0 1"/> 
                
        <!-- Changed pos: lowered to Z=0.2 and added quat to rotate 90 degrees around Y axis -->
        <body name="torso" pos="0 0 0.1">
            <freejoint name="root"/>
            <geom name="torso_geom" type="capsule" size="0.1 0.2" rgba="0.7 0.6 0.5 1"/>
            
            <!-- Head: Positioned at the top of torso, looking up -->
            <body name="head" pos="0 0 0.3">
                <joint name="neck" type="ball" pos="0 0 0"/>
                <geom name="head_geom" type="sphere" size="0.08" rgba="0.8 0.7 0.6 1"/>
            </body>

            <!-- Right Arm -->
            <body name="right_arm" pos="0.15 0 0.2">
                <joint name="right_shoulder" type="ball" pos="0 0 0"/>
                <geom name="r_arm_geom" type="capsule" size="0.03 0.15" pos="0 0 -0.15" rgba="0.7 0.6 0.5 1"/>
                
                <body name="right_forearm" pos="0 0 -0.3">
                    <joint name="right_elbow" type="hinge" axis="0 1 0" pos="0 0 0"/>
                    <geom name="r_forearm_geom" type="capsule" size="0.025 0.15" pos="0 0 -0.15" rgba="0.7 0.6 0.5 1"/>
                </body>
            </body>

            <!-- Left Arm -->
            <body name="left_arm" pos="-0.15 0 0.2">
                <joint name="left_shoulder" type="ball" pos="0 0 0"/>
                <geom name="l_arm_geom" type="capsule" size="0.03 0.15" pos="0 0 -0.15" rgba="0.7 0.6 0.5 1"/>
                
                <body name="left_forearm" pos="0 0 -0.3">
                    <joint name="left_elbow" type="hinge" axis="0 1 0" pos="0 0 0"/>
                    <geom name="l_forearm_geom" type="capsule" size="0.025 0.15" pos="0 0 -0.15" rgba="0.7 0.6 0.5 1"/>
                </body>
            </body>

            <!-- Right Leg -->
            <body name="right_leg" pos="0.1 0 -0.2">
                <joint name="right_hip" type="ball" pos="0 0 0"/>
                <geom name="r_thigh_geom" type="capsule" size="0.05 0.2" pos="0 0 -0.2" rgba="0.6 0.5 0.4 1"/>
                
                <body name="right_calf" pos="0 0 -0.4">
                    <joint name="right_knee" type="hinge" axis="0 1 0" pos="0 0 0"/>
                    <geom name="r_calf_geom" type="capsule" size="0.04 0.2" pos="0 0 -0.2" rgba="0.6 0.5 0.4 1"/>
                </body>
            </body>
^  
            <!-- Left Leg -->
            <body name="left_leg" pos="-0.1 0 -0.2">
                <joint name="left_hip" type="ball" pos="0 0 0"/>
                <geom name="l_thigh_geom" type="capsule" size="0.05 0.2" pos="0 0 -0.2" rgba="0.6 0.5 0.4 1"/>
                
                <body name="left_calf" pos="0 0 -0.4">
                    <joint name="left_knee" type="hinge" axis="0 1 0" pos="0 0 0"/>
                    <geom name="l_calf_geom" type="capsule" size="0.04 0.2" pos="0 0 -0.2" rgba="0.6 0.5 0.4 1"/>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="right_shoulder_motor" joint="right_shoulder" gear="20"/>
        <motor name="left_shoulder_motor" joint="left_shoulder" gear="20"/>
        <motor name="right_elbow_motor" joint="right_elbow" gear="40"/>
        <motor name="left_elbow_motor" joint="left_elbow" gear="40"/>
        <motor name="right_hip_motor" joint="right_hip" gear="30"/>
        <motor name="left_hip_motor" joint="left_hip" gear="30"/>
        <motor name="right_knee_motor" joint="right_knee" gear="80"/>
        <motor name="left_knee_motor" joint="left_knee" gear="80"/>
    </actuator>
</mujoco>