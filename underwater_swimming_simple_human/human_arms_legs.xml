<mujoco model="human_swimmer">
    <option gravity="0 0 0" timestep="0.005" viscosity="0.0013" density="1000">
        <flag energy="enable"/>
    </option>

    <asset>
        <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
        <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
    </asset>

    <default>
        <joint damping="0.5"/>
        <geom friction="0.01 0.01 0.01"/>
    </default>

    <worldbody>
        <!-- Main Directional Light -->
        <light name="sun" pos="0 0 10" dir="0.2 -0.2 -1" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3" castshadow="true"/>
        <!-- Fill Light -->
        <light name="fill" pos="0 0 -5" dir="0 0 1" diffuse="0.3 0.3 0.4" specular="0.1 0.1 0.1"/>
        <!-- Ambient Light -->
        <light name="ambient" pos="0 0 0" diffuse="0.1 0.1 0.2" specular="0 0 0"/>

        <geom name="floor" type="plane" size="0 0 .05" material="grid" condim="3" rgba="0.1 0.4 0.6 1"/>

        <camera name="main_camera" pos="10 10 10" xyaxes="1 0 0 0 0 1"/>
        <camera name="chase_cam" pos="0 -4 2" mode="trackcom" xyaxes="0 1 0 0 0 1"/> 
                
        <body name="torso" pos="0 0 2.0">
            <freejoint name="root"/>
            <geom name="chest" type="capsule" size="0.15 0.1 0.2" rgba="0.7 0.7 0.7 1" />
            
            <!-- Head -->
            <body name="head" pos="0 0 0.3">
                <geom type="sphere" size="0.1" rgba="0.9 0.8 0.7 1"/>
            </body>

            <!-- Right Arm -->
            <body name="right_arm" pos="0.2 0 0.1">
                <joint name="right_shoulder" type="ball"/>
                <!-- Upper Arm: From shoulder to elbow -->
                <geom type="capsule" size="0.04" fromto="0 0 0 0 0 -0.3" rgba="0 0.8 0 1"/>
                
                <!-- Right Forearm -->
                <body name="right_forearm" pos="0 0 -0.3">
                    <joint name="right_elbow" type="hinge" axis="0 1 0" range="0 2.5" limited="true"/>
                    <geom type="capsule" size="0.035" fromto="0 0 0 0 0 -0.3" rgba="0 0.7 0 1"/>
                </body>
            </body>

            <!-- Left Arm -->
            <body name="left_arm" pos="-0.2 0 0.1">
                <joint name="left_shoulder" type="ball"/>
                <!-- Upper Arm: From shoulder to elbow -->
                <geom type="capsule" size="0.04" fromto="0 0 0 0 0 -0.3" rgba="0 0.8 0 1"/>
                
                <!-- Left Forearm -->
                <body name="left_forearm" pos="0 0 -0.3">
                    <joint name="left_elbow" type="hinge" axis="0 1 0" range="0 2.5" limited="true"/>
                    <geom type="capsule" size="0.035" fromto="0 0 0 0 0 -0.3" rgba="0 0.7 0 1"/>
                </body>
            </body>

        <!-- Left Leg -->
            <body name="left_leg" pos="-0.1 0 -0.3">
                <!-- 1. Flexion/Extension: Moving leg Forward/Backward -->
                <joint name="left_hip_flex" type="hinge" axis="1 0 0" range="-1.0 2.0" limited="true"/>

                <!-- 2. Abduction/Adduction: Moving leg Out/In (Sideways) -->
                <joint name="left_hip_abd"  type="hinge" axis="0 -1 0" range="-0.5 0.5" limited="true"/>

                <!-- 3. Internal/External Rotation: Twisting the leg -->
                <joint name="left_hip_rot"  type="hinge" axis="0 0 -1" range="-0.2 0.2" limited="true"/>

                <!-- Thigh: From hip down to knee -->
                <geom type="capsule" size="0.05" fromto="0 0 0 0 0 -0.4" rgba="0 0.6 0 1"/>
                
                <!-- Left Lower Leg -->
                <body name="left_calf" pos="0 0 -0.4">
                    <joint name="left_knee" type="hinge" axis="0 1 0" range="0 2.0" limited="true"/>
                    <geom type="capsule" size="0.04" fromto="0 0 0 0 0 -0.4" rgba="0 0.5 0 1"/>
                </body>
            </body>
        
        <body name="right_leg" pos="0.1 0 -0.3">
                <!-- 1. Flexion/Extension: Moving leg Forward/Backward -->
                <joint name="right_hip_flex" type="hinge" axis="1 0 0" range="-1.0 2.0" limited="true"/>

                <!-- 2. Abduction/Adduction: Moving leg Out/In (Sideways) -->
                <joint name="right_hip_abd"  type="hinge" axis="0 1 0" range="-0.5 0.5" limited="true"/>

                <!-- 3. Internal/External Rotation: Twisting the leg -->
                <joint name="right_hip_rot"  type="hinge" axis="0 0 1" range="-0.2 0.2" limited="true"/>
               
                <!-- Thigh: From hip down to knee -->
                <geom type="capsule" size="0.05" fromto="0 0 0 0 0 -0.4" rgba="0 0.6 0 1"/>
                
                <!-- Right Lower Leg -->
                <body name="right_calf" pos="0 0 -0.4">
                    <joint name="right_knee" type="hinge" axis="0 1 0" range="0 2.0" limited="true"/>
                    <geom type="capsule" size="0.04" fromto="0 0 0 0 0 -0.4" rgba="0 0.5 0 1"/>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <!-- Shoulder actuators -->
        <motor name="right_shoulder_motor" joint="right_shoulder" gear="20"/>
        <motor name="left_shoulder_motor" joint="left_shoulder" gear="20"/>
        <!-- Elbow actuators -->
        <motor name="right_elbow_motor" joint="right_elbow" gear="40"/>
        <motor name="left_elbow_motor" joint="left_elbow" gear="40"/>

        <!-- Right Hip Motors -->
        <motor name="right_hip_flex_motor" joint="right_hip_flex" gear="150"/>
        <motor name="right_hip_abd_motor"  joint="right_hip_abd"  gear="60"/>
        <motor name="right_hip_rot_motor"  joint="right_hip_rot"  gear="40"/>

        <!-- Left Hip Motors -->
        <motor name="left_hip_flex_motor"  joint="left_hip_flex"  gear="150"/>
        <motor name="left_hip_abd_motor"   joint="left_hip_abd"   gear="60"/>
        <motor name="left_hip_rot_motor"   joint="left_hip_rot"   gear="40"/>
        <!-- Knee actuators -->
        <motor name="right_knee_motor" joint="right_knee" gear="80"/>
        <motor name="left_knee_motor" joint="left_knee" gear="80"/>
    </actuator>
</mujoco>