<mujoco model="worm_swimmer">
    <option gravity="0 0 -0.1" timestep="0.01" viscosity="1.0" density="1000" integrator="implicitfast">
        <flag energy="enable"/>
    </option>

    <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
    </asset>

    <default>
        <joint damping="0.5"/>
        <geom friction="0.1 0.1 0.1"/>
    </default>

    <worldbody>
        <light name="sun" pos="0 0 10" dir="0.2 -0.2 -1"
               diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3"
               castshadow="true"/>
        <light name="fill" pos="0 0 -5" dir="0 0 1"
               diffuse="0.3 0.3 0.4" specular="0.1 0.1 0.1"/>
        <light name="ambient" pos="0 0 0"
               diffuse="0.12 0.12 0.2" specular="0 0 0"/>
        <geom name="floor" type="plane" size="0 0 .05" material="grid" condim="3" rgba="0.1 0.4 0.6 1"/>

        <!-- Water visualiser (purely visual, no collisions) -->
        <geom name="water_surface" type="plane" size="10 10 0.01" pos="0 0 10.0" rgba="0 0.5 1 0.3" contype="0" conaffinity="0"/>

        <camera name="main_camera"
                pos="-4 -4 13"
                xyaxes="1 0 0 0 0 1"/>

        <camera name="top_follow" pos="0 0 10" xyaxes="1 0 0 0 0 1" mode="trackcom"/>        

        
        <body name="segment1" pos="0 0 10">
            <freejoint name="root"/>
            <geom type="capsule"
                size="0.05"
                fromto="0 0 0 0.5 0 0"
                fluidshape="ellipsoid"
                fluidcoef="0.5 0.25 1.5 1.0 1.0"
                rgba="0 1 0 1"/>

            <body name="segment2" pos="0.5 0 0">
                <joint name="joint1" type="hinge" axis="0 1 0" pos="0 0 0"/>
                <geom type="capsule"
                    size="0.05"
                    fluidshape="ellipsoid"
                    fluidcoef="0.5 0.25 1.5 1.0 1.0"
                    fromto="0 0 0 0.5 0 0"
                    rgba="0 0.8 0 1"/>

                <body name="segment3" pos="0.5 0 0">
                    <joint name="joint2" type="hinge" axis="0 1 0" pos="0 0 0"/>
                    <geom type="capsule"
                        size="0.05"
                        fluidshape="ellipsoid"
                        fluidcoef="0.5 0.25 1.5 1.0 1.0"
                        fromto="0 0 0 0.5 0 0"
                        rgba="0 0.6 0 1"/>

                    <body name="head" pos="0.5 0 0">
                        <joint name="joint3" type="hinge" axis="0 1 0" pos="0 0 0"
                            limited="true" range="-30 30"/>
                        <geom type="capsule"
                            size="0.05"
                            fromto="0 0 0 0.2 0 0"
                            fluidshape="ellipsoid"
                            fluidcoef="0.5 0.25 1.5 1.0 1.0"
                            rgba="1 0.3 0.1 1"/>
                    </body>

                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="muscle1" joint="joint1" gear="10"/>
        <motor name="muscle2" joint="joint2" gear="10"/>
        <motor name="muscle3" joint="joint3" gear="10"/>
    </actuator>
</mujoco>