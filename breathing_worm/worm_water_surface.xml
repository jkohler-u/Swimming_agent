<mujoco model="worm_swimmer">
    <option gravity="0 0 -0.1" timestep="0.01" viscosity="1.0" density="1000" integrator="implicitfast">
        <flag energy="enable"/>
    </option>

    <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
    </asset>

    <default>
        <joint damping="0.5"/>
        <geom friction="0.1 0.1 0.1"/>
    </default>

    <worldbody>
        <light name="main_light"
            pos="0 -4 8"
            dir="0 1 -1"
            diffuse="1 1 1"
            specular="0.3 0.3 0.3"/>

        <light name="fill_light"
            pos="4 4 6"
            dir="-1 -1 -1"
            diffuse="0.5 0.5 0.5"
            specular="0.1 0.1 0.1"/>
        <geom name="floor" type="plane" size="0 0 .05" material="grid" condim="3" rgba="0.1 0.4 0.6 1"/>

        <!-- Water visualiser (purely visual, no collisions) -->
        <!-- Water visualiser -->
        <geom name="water_surface"
            type="plane"
            size="20 20 0.01"
            pos="0 0 3.0"
            rgba="0 0.5 1 0.15"
            contype="0"
            conaffinity="0"/>

        <!-- Better side-follow camera -->
        <camera name="side_follow"
                mode="trackcom"
                pos="-1.0 -4.0 3.8"
                xyaxes="1 0 0 0 0 1"/>

        <!-- Oblique camera: best for seeing swimming motion -->
        <camera name="oblique_follow"
                mode="trackcom"
                pos="-2.5 -4.0 5"
                xyaxes="0.85 -0.5 0 0.25 0.45 0.86"/>

        <!-- Top camera, but higher and useful for path tracking -->
        <camera name="top_follow"
                mode="trackcom"
                pos="0 0 8"
                xyaxes="1 0 0 0 1 0"/>
        
        <body name="segment1" pos="0 0 3.05">
            <freejoint name="root"/>
            <geom type="capsule"
                size="0.05"
                fromto="0 0 0 0.5 0 0"
                fluidshape="ellipsoid"
                fluidcoef="0.5 0.25 1.5 1.0 1.0"
                rgba="0 1 0 1"/>

            <body name="segment2" pos="0.5 0 0">
                <joint name="joint1" type="hinge" axis="0 1 0" pos="0 0 0"/>
                <geom type="capsule"
                    size="0.05"
                    fluidshape="ellipsoid"
                    fluidcoef="0.5 0.25 1.5 1.0 1.0"
                    fromto="0 0 0 0.5 0 0"
                    rgba="0 0.8 0 1"/>

                <body name="segment3" pos="0.5 0 0">
                    <joint name="joint2" type="hinge" axis="0 1 0" pos="0 0 0"/>
                    <geom type="capsule"
                        size="0.05"
                        fluidshape="ellipsoid"
                        fluidcoef="0.5 0.25 1.5 1.0 1.0"
                        fromto="0 0 0 0.5 0 0"
                        rgba="0 0.6 0 1"/>

                    <body name="head" pos="0.5 0 0">
                        <joint name="joint3" type="hinge" axis="0 1 0" pos="0 0 0"
                            limited="true" range="-30 30"/>
                        <geom type="capsule"
                            size="0.05"
                            fromto="0 0 0 0.2 0 0"
                            fluidshape="ellipsoid"
                            fluidcoef="0.5 0.25 1.5 1.0 1.0"
                            rgba="1 0.3 0.1 1"/>
                    </body>

                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="muscle1" joint="joint1" gear="60"/>
        <motor name="muscle2" joint="joint2" gear="60"/>
        <motor name="muscle3" joint="joint3" gear="60"/>
    </actuator>
</mujoco>