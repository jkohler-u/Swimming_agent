<mujoco model="worm_swimmer">
    <option gravity="0 0 -9.81"
            timestep="0.01"
            integrator="implicitfast">
        <flag energy="enable"/>
    </option>

    <asset>
        <texture name="grid" type="2d" builtin="checker" width="512" height="512"
                 rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
        <material name="grid" texture="grid" texrepeat="1 1"
                  texuniform="true" reflectance=".2"/>
    </asset>

    <default>
        <joint damping="0.5"/>
        <geom friction="0.1 0.1 0.1"/>
    </default>

    <worldbody>
        <light name="top" pos="0 0 20" mode="trackcom"/>
        <light diffuse=".5 .5 .5" pos="0 0 20" dir="0 0 -1"/>

        <geom name="floor" type="plane" size="0 0 .05"
              material="grid" condim="3" rgba="0.1 0.4 0.6 1"/>

        <!-- Visual water surface only -->
        <geom name="water_surface"
              type="plane"
              size="10 10 0.01"
              pos="0 0 3.0"
              rgba="0 0.5 1 0.3"
              contype="0"
              conaffinity="0"/>


        <camera name="main_camera"
                pos="-3 -3 10"
                xyaxes="1 0 0 0 0 1"/>

        <camera name="top_follow"
                pos="0 0 10"
                xyaxes="1 0 0 0 0 1"
                mode="trackcom"/>

        <body name="segment1" pos="0 0 1">
            <freejoint name="root"/>
            <geom type="capsule"
                  size="0.05"
                  fromto="0 0 0 0.5 0 0"
                  rgba="0 1 0 1"/>

            <body name="segment2" pos="0.5 0 0">
                <joint name="joint1" type="hinge" axis="0 1 0" pos="0 0 0"/>
                <geom type="capsule"
                      size="0.05"
                      fromto="0 0 0 0.5 0 0"
                      rgba="0 0.8 0 1"/>

                <body name="segment3" pos="0.5 0 0">
                    <joint name="joint2" type="hinge" axis="0 1 0" pos="0 0 0"/>
                    <geom type="capsule"
                          size="0.05"
                          fromto="0 0 0 0.5 0 0"
                          rgba="0 0.6 0 1"/>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="muscle1" joint="joint1" gear="3"/>
        <motor name="muscle2" joint="joint2" gear="3"/>
    </actuator>
</mujoco>